# =========================================================================
# Hardened OpenVPN + Logto Portal - Environment Variables Configuration
# =========================================================================
# Copy this file to '.env' on your target machine and update the values.
#
# IMPORTANT: DO NOT commit your actual '.env' file containing real secrets
# to Git. It is already ignored by default via '.gitignore'.

# ── LOGTO MACHINE-TO-MACHINE (M2M) CREDENTIALS ────────────────────────────
# 1. Open your Logto Admin Console (default http://localhost:3002)
# 2. Navigate to "Applications" -> Find or create a Machine-to-Machine app.
# 3. Assign the "Logto Management API access" role to this M2M application.
# 4. Copy the Application ID and Application Secret to the variables below.
LOGTO_M2M_APP_ID=6oi8l4d2919eknf6t3yn9
LOGTO_M2M_APP_SECRET=sAXjILcsNS9ipQxW0vEAs9wZlWPuElAe

# ── NEXT.JS COOKIE SESSION ENCRYPTION ─────────────────────────────────────
# A secure, random 32+ character string used to encrypt the Next.js session cookie.
# You can generate a random string using: openssl rand -base64 32
LOGTO_COOKIE_SECRET=5MpID6PGAaoygBvHyjU3e90a0g72zozo

# ── HAPROXY LOAD BALANCER CONFIGURATION ───────────────────────────────────
# The load balancing algorithm for HAProxy.
# Options:
#   - leastconn: Routes new connections to the server with fewest active connections (Recommended)
#   - source: Pin clients to nodes persistently based on their source IP address
LB_ALGORITHM=leastconn
